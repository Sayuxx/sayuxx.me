{
	"name": "figmakit",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"build:code": "vite build --config vite.config.code.ts",
		"build:ui": "vite build --config vite.config.ui.ts",
		"build": "npm run build:code && npm run build:ui",
		"watch:code": "vite build --config vite.config.code.ts --watch",
		"watch:ui": "vite build --config vite.config.ui.ts --watch",
		"check": "svelte-check --tsconfig ./tsconfig.json",
		"test": "vitest run"
	},
	"devDependencies": {
		"@figma/plugin-typings": "^1.108.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/culori": "^4.0.1",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"tslib": "^2.8.1",
		"typescript": "^6.0.2",
		"vite": "^8.0.7",
		"vite-plugin-singlefile": "^2.3.1",
		"vitest": "^4.1.4"
	},
	"dependencies": {
		"culori": "^4.0.2"
	}
}
